{
  "name": "cruiser-spa",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "emulators": "firebase emulators:start --project carfollow-75750",
    "setup:java": "powershell -ExecutionPolicy Bypass -File scripts/setupLocalJava.ps1",
    "rules:check": "node scripts/checkFirebaseRules.mjs",
    "seed:firebase": "node scripts/seedFirebase.mjs",
    "test": "vitest",
    "test:run": "vitest run",
    "test:emulators": "node scripts/runFirebaseEmulatorTests.mjs",
    "test:functions": "npm --prefix functions test",
    "lint:functions": "npm --prefix functions run lint",
    "backup:list": "firebase firestore:backups:list --project carfollow-75750",
    "backup:schedules": "firebase firestore:backups:schedules:list --project carfollow-75750",
    "postman:generate": "node scripts/generatePostmanMapE2E.mjs",
    "postman:test": "node scripts/runPostmanMapE2E.mjs",
    "postman:cleanup": "node scripts/cleanupPostmanE2E.mjs"
  },
  "dependencies": {
    "@react-google-maps/api": "^2.20.8",
    "firebase": "^12.15.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@tailwindcss/vite": "^4.1.11",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^5.0.0",
    "dotenv": "^17.4.2",
    "firebase-tools": "^15.23.0",
    "happy-dom": "^20.10.6",
    "jsdom": "^27.0.1",
    "tailwindcss": "^4.1.11",
    "vite": "^7.0.0",
    "vitest": "^4.1.10"
  }
}
