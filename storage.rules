rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isKnownApp(appId) {
      return appId == 'cruiser-app-prod';
    }

    function isSignedIn() {
      return request.auth != null &&
        (
          !request.auth.token.keys().hasAny(['firebase']) ||
          request.auth.token.firebase.sign_in_provider != 'anonymous'
        );
    }

    function isImageUnderLimit(maxBytes) {
      return request.resource.size < maxBytes &&
        request.resource.contentType.matches('image/.*');
    }

    match /artifacts/{appId}/users/{userId}/avatars/{fileName} {
      allow read: if isKnownApp(appId) && isSignedIn();
      allow create, update: if isKnownApp(appId) &&
        isSignedIn() &&
        request.auth.uid == userId &&
        isImageUnderLimit(5 * 1024 * 1024);
      allow delete: if isKnownApp(appId) && isSignedIn() && request.auth.uid == userId;
    }

    match /artifacts/{appId}/mapNodes/{nodeId}/photos/{userId}/{fileName} {
      allow read: if isKnownApp(appId) && isSignedIn();
      allow create, update: if isKnownApp(appId) &&
        isSignedIn() &&
        request.auth.uid == userId &&
        isImageUnderLimit(10 * 1024 * 1024);
      allow delete: if isKnownApp(appId) && isSignedIn() && request.auth.uid == userId;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
