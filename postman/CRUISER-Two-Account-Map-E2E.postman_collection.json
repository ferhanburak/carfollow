      "name": "00 - Authentication",
      "item": [
        {
          "name": "Sign In Account A",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Account A signed in\", () => pm.response.to.have.status(200));",
                  "const auth = pm.response.json();",
                  "pm.environment.set(\"idTokenA\", auth.idToken);",
                  "pm.environment.set(\"refreshTokenA\", auth.refreshToken);",
                  "pm.environment.set(\"uidA\", auth.localId);",
                  "pm.collectionVariables.set(\"runId\", Date.now().toString());"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{emailA}}\",\n  \"password\": \"{{passwordA}}\",\n  \"returnSecureToken\": true\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{authBase}}/accounts:signInWithPassword?key={{apiKey}}",
              "host": [
                "{{authBase}}"
              ],
              "path": [
                "accounts:signInWithPassword"
              ],
              "query": [
                {
                  "key": "key",
                  "value": "{{apiKey}}"
                }
              ]
            }
          }
        },
        {
          "name": "Sign In Account B",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Account B signed in\", () => pm.response.to.have.status(200));",
                  "const auth = pm.response.json();",
                  "pm.environment.set(\"idTokenB\", auth.idToken);",
                  "pm.environment.set(\"refreshTokenB\", auth.refreshToken);",
                  "pm.environment.set(\"uidB\", auth.localId);",
                  "pm.test(\"Accounts are different\", () => pm.expect(auth.localId).to.not.eql(pm.environment.get(\"uidA\")));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{emailB}}\",\n  \"password\": \"{{passwordB}}\",\n  \"returnSecureToken\": true\n}",
              "options": {
                "raw": {
                  "language": "json"
